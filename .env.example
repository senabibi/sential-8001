# Copy this to .env and fill in your values

# LLM — Groq (free tier available at console.groq.com)
GROQ_API_KEY=gsk_...

# Kraken CeFi
KRAKEN_API_KEY=your_key
KRAKEN_API_SECRET=your_secret
KRAKEN_CLI_PATH=kraken        # Path to kraken CLI binary

# On-chain (Base L2) — teammate fills these in
AGENT_WALLET_PRIVATE_KEY=0x...
BASE_RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# ERC-8004 contract addresses (from Surge hackathon docs)
IDENTITY_REGISTRY_ADDRESS=0x...
REPUTATION_REGISTRY_ADDRESS=0x...
VALIDATION_REGISTRY_ADDRESS=0x...
RISK_ROUTER_ADDRESS=0x...

# Capital Vault (assigned at hackathon registration)
CAPITAL_VAULT_AGENT_ID=your_agent_id

# Agent config
TRADE_MODE=paper
ENABLE_DEFI=false
CYCLE_INTERVAL_SECONDS=60
